{
  "version": 2,
  "routes": [
    {
      "src": "/api/gemini",
      "dest": "api/gemini.js"
    },
    {
      "src": "/api/scrape",
      "dest": "api/scrape.js"
    },
    {
      "src": "/api/auth",
      "dest": "api/auth.js"
    },
    {
      "src": "/api/refresh",
      "dest": "api/refresh.js"
    },
    {
      "src": "/api/logout",
      "dest": "api/logout.js"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
